#!/usr/bin/env python3
"""
Unified analysis script – reads validation CSV and generates plots/stats.
Usage: python code/analyze_results.py --dataset german-credit
       or --validation_file results/custom.csv
"""
import argparse
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
import re
from pathlib import Path

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--dataset", choices=["german-credit", "compas"],
                        help="Dataset name (used to locate default validation file).")
    parser.add_argument("--validation_file", help="Override path to validation CSV")
    args = parser.parse_args()

    if args.validation_file:
        val_file = args.validation_file
    elif args.dataset:
        # Try to find a validation file in results/
        results_dir = Path("results")
        candidates = list(results_dir.glob(f"{args.dataset}_*_validation.csv"))
        if not candidates:
            print(f"No validation file found for dataset {args.dataset} in results/")
            return
        # Take the first one (or you could let user specify method)
        val_file = str(candidates[0])
        print(f"Using {val_file}")
    else:
        print("Please provide either --dataset or --validation_file")
        return

    df_cf = pd.read_csv(val_file)
    print(f"Loaded {len(df_cf)} counterfactuals from {df_cf['applicant_idx'].nunique()} applicants.")

    df_cf['is_valid'] = df_cf['conforms'] == True

    # Violation breakdown
    def extract_rule(msg):
        if pd.isna(msg) or msg == "No violation":
            return None
        match = re.search(r'(\w+Rule)', msg)
        if match:
            return match.group(0)
        return msg.split(':')[0].strip()

    df_cf['rule'] = df_cf['violations'].apply(lambda x: extract_rule(x) if x != "No violation" else None)
    invalid_cfs = df_cf[~df_cf['is_valid']]
    rule_counts = invalid_cfs['rule'].value_counts().dropna()
    print("\n=== Violation counts per rule ===")
    print(rule_counts)

    # Compare valid vs invalid on metrics
    valid = df_cf[df_cf['is_valid']]
    invalid = df_cf[~df_cf['is_valid']]
    metrics = ['distance', 'cost']
    extra_cols = [c for c in df_cf.columns if c in ['age', 'priors_count', 'credit_amount', 'duration']]

    print("\n=== Comparison: Valid vs Invalid ===")
    for metric in metrics + extra_cols:
        if metric not in df_cf.columns:
            continue
        v_mean = valid[metric].mean()
        inv_mean = invalid[metric].mean()
        _, p = stats.mannwhitneyu(valid[metric], invalid[metric], alternative='two-sided')
        print(f"{metric}: Valid mean={v_mean:.2f}, Invalid mean={inv_mean:.2f}, p={p:.4f}")

    # Determine output prefix from filename
    stem = Path(val_file).stem  # e.g., "german-credit_dice_validation"
    output_prefix = stem.replace("_validation", "")

    # Plot 1: Number of valid CFs per applicant
    plt.figure(figsize=(8,5))
    sns.histplot(df_cf.groupby('applicant_idx')['is_valid'].sum(), bins=range(0, 16, 1), kde=False)
    plt.title(f"Number of Valid CFs per Applicant ({output_prefix})")
    plt.xlabel("Valid CFs")
    plt.ylabel("Number of Applicants")
    plt.savefig(f"results/valid_cfs_per_applicant_{output_prefix}.png", dpi=150)
    plt.close()

    # Plot 2: Violation per rule (if any)
    if len(rule_counts) > 0:
        plt.figure(figsize=(10,6))
        rule_counts.sort_values(ascending=False).plot(kind='bar')
        plt.title(f"Violations per SHACL Rule ({output_prefix})")
        plt.ylabel("Number of violations")
        plt.xticks(rotation=45, ha='right')
        plt.tight_layout()
        plt.savefig(f"results/violation_per_rule_{output_prefix}.png", dpi=150)
        plt.close()

    # (Boxplot removed as requested)

    # Summary table
    cols_to_agg = ['distance', 'cost'] + [f for f in extra_cols if f in df_cf.columns]
    summary_stats = df_cf.groupby('is_valid')[cols_to_agg].agg(['mean', 'std', 'min', 'max']).round(2)
    print("\n=== Summary stats (Valid vs Invalid) ===")
    print(summary_stats)
    summary_stats.to_csv(f"results/summary_stats_{output_prefix}.csv")

    # Correlation
    corr = df_cf[['distance', 'cost']].corr().iloc[0,1]
    print(f"\nCorrelation distance–cost: {corr:.3f}")

    # Text report
    with open(f"results/analysis_{output_prefix}_report.txt", "w") as f:
        f.write(f"COUNTERFACTUAL ANALYSIS – {output_prefix.upper()}\n")
        f.write("=" * 50 + "\n\n")
        f.write(f"Total CFs: {len(df_cf)}\n")
        f.write(f"Valid CFs: {valid.shape[0]} ({valid.shape[0]/len(df_cf):.2%})\n")
        f.write(f"Invalid CFs: {invalid.shape[0]} ({invalid.shape[0]/len(df_cf):.2%})\n\n")
        f.write("Violation counts:\n")
        f.write(rule_counts.to_string())
        f.write("\n\nComparison of valid vs invalid:\n")
        f.write(summary_stats.to_string())
        f.write(f"\n\nCorrelation distance-cost: {corr:.3f}\n")
        f.write("\nMann-Whitney tests:\n")
        for metric in metrics + extra_cols:
            if metric not in df_cf.columns:
                continue
            _, p = stats.mannwhitneyu(valid[metric], invalid[metric], alternative='two-sided')
            f.write(f"{metric}: p={p:.4f}\n")

    print(f"Report saved to results/analysis_{output_prefix}_report.txt")

if __name__ == "__main__":
    main()