# ================================================================
#  SPARSITY – only for counterfactuals
#  UPDATED: max 8 changes to match 8 mutable features
# ================================================================
ex:SparsityRule
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Too many features changed (max 8)." ;
        sh:select '''
PREFIX ex: <http://example.org/compas/>
SELECT $this WHERE {
    $this ex:isCounterfactual true .
    $this ex:numberOfChangedFeatures ?n .
    FILTER(?n > 8)
}
''' ;
    ] .